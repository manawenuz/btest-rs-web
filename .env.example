# ─── Database ────────────────────────────────────────────────────────
# For Vercel/Neon: auto-populated by the Neon integration
# For Docker: set POSTGRES_PASSWORD below, DATABASE_URL is built automatically
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# POSTGRES_URL=postgres://...  (legacy alias, also supported)

# Docker only — password for the local Postgres container
# POSTGRES_PASSWORD=changeme

# Docker + Caddy only — your domain (Caddy auto-provisions HTTPS via Let's Encrypt)
# DOMAIN=btest.example.com

# ─── Auth ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Optional — protects the /api/migrate endpoint
# MIGRATE_SECRET=some-secret-value

# ─── Email (optional) ───────────────────────────────────────────────
# Password reset emails via Resend (https://resend.com)
# Without this, the "Forgot password?" link won't appear on the login page.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=btest-rs-web <noreply@yourdomain.com>

# ─── App URL ─────────────────────────────────────────────────────────
# Your app's public URL (used in password reset email links)
# NEXT_PUBLIC_APP_URL=https://btest.example.com
