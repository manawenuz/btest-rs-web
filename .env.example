# Database — Neon Postgres (auto-populated when you add the Neon integration on Vercel)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# Legacy alias — also supported
# POSTGRES_URL=postgres://...

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# Optional — protects the /api/migrate endpoint
# MIGRATE_SECRET=some-secret-value

# Optional — password reset emails via Resend (https://resend.com)
# Without this, the "Forgot password?" link won't appear on the login page.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=btest-rs-web <noreply@yourdomain.com>

# Optional — your app's public URL (used in reset email links)
# NEXT_PUBLIC_APP_URL=https://btest.example.com
